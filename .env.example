PORT=3080
DATA_DIR=./data
TV_LIBRARY=./media/tv
MOVIE_LIBRARY=./media/movies
DOWNLOADS=./media/downloads
AUTO_APPROVE=true
STALE_DAYS=365
STALE_DELETE_GRACE_DAYS=2
MONITOR_INTERVAL_MS=120000
IMPORT_INTERVAL_MS=30000

# Household admin (created on first boot if DB empty)
ADMIN_USER=brad
ADMIN_PASS=changeme

# NZBGet on R620
NZBGET_URL=http://127.0.0.1:6789
NZBGET_USER=nzbget
NZBGET_PASS=tegbzn6789
NZBGET_CATEGORY=tv-orch
NZBGET_MOVIE_CATEGORY=movie-orch

# Newznab indexers
NZBGEEK_URL=https://api.nzbgeek.info
NZBGEEK_API_KEY=
NZBFINDER_URL=https://nzbfinder.ws
NZBFINDER_API_KEY=

# The Movie Database (free) — movie search + posters
TMDB_API_KEY=

# Tautulli — Now Playing, usage drawer, channel drop-after-watch
TAUTULLI_URL=
TAUTULLI_API_KEY=

# Quality preference: 1080p | 720p | any
QUALITY_PROFILE=1080p

# Plex (for stale media / optional library refresh)
PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=

# Push notifications (optional — leave blank to skip)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

SESSION_SECRET=change-this-to-a-long-random-string
